generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MENTOR
  CAMPUS_MANAGER
}

enum Visibility {
  PUBLIC
  UNIVERSITY_ONLY
}

model University {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  users     User[]
  notes     Note[]
  posts     Post[] // Back-relation for unified posts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String             @id @default(uuid())
  email           String             @unique
  name            String             @default("User")
  password        String
  role            Role               @default(STUDENT)
  university      University?        @relation(fields: [universityId], references: [id])
  universityId    String? // Made optional for onboarding flow
  batchYear       Int?
  lastActiveAt    DateTime           @default(now())
  
  // Relations
  notes           Note[]
  placements      PlacementPost[]
  hackathons      Hackathon[]
  threads         DiscussionThread[]
  replies         DiscussionReply[]
  announcements   Announcement[]
  posts           Post[] // Unified dashboard posts
  likes           Like[] // Back-relation for likes
  applications    HackathonApplication[] // Back-relation for hackathons
  upvotes         Upvote[]
  bookmarks       Bookmark[]

  receivedNotifications Notification[] @relation("UserNotifications")
  sentNotifications     Notification[] @relation("SentNotifications")

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([universityId])
}

model Post {
  id             String      @id @default(uuid())
  content        String      @db.Text

  author         User        @relation(fields: [authorId], references: [id])
  authorId       String
  university     University  @relation(fields: [universityId], references: [id])
  universityId   String
  
  // Scope: COLLEGE (university only) or KALVIUM (public to network)
  scope          String      @default("COLLEGE")
  
  likeCount      Int         @default(0)
  likes          Like[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([universityId, scope, createdAt])
  @@index([authorId])
}

model Like {
  id             String      @id @default(uuid())
  user           User        @relation(fields: [userId], references: [id])
  userId         String
  post           Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String

  createdAt      DateTime    @default(now())

  @@unique([userId, postId])
}

model Note {
  id             String      @id @default(uuid())
  title          String
  content        String      @db.Text

  fileUrls       String[]    @default([])
  semester       Int
  visibility     Visibility  @default(UNIVERSITY_ONLY)
  
  // Relations
  university     University  @relation(fields: [universityId], references: [id])
  universityId   String
  author         User        @relation(fields: [authorId], references: [id])
  authorId       String

  // AI Caching
  aiSummary      String?     @db.Text

  aiKeyPoints    Json?       // array of strings
  aiTopics       Json?       // array of exam topics/questions
  aiAnalyzedAt   DateTime?
  
  // Denormalized Summary
  upvoteCount    Int         @default(0)
  
  // Many-to-Many Tags
  tags           NoteTag[]
  upvotes        Upvote[]    @relation("NoteUpvotes")
  bookmarks      Bookmark[]  @relation("NoteBookmarks")

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([universityId, visibility, createdAt])
  @@index([authorId])
}

model PlacementPost {
  id             String      @id @default(uuid())
  company        String
  role           String
  content        String      @db.Text
  fileUrls       String[]    @default([])

  rounds         Json?       // Structured round details

  // AI Caching
  aiRoundBreakdown Json?
  aiPrepTopics     Json?
  aiPrepChecklist  Json?
  aiAnalyzedAt     DateTime?
  
  // Relations
  author         User        @relation(fields: [authorId], references: [id])
  authorId       String
  
  // Denormalized Summary
  upvoteCount    Int         @default(0)
  
  upvotes        Upvote[]    @relation("PlacementUpvotes")
  bookmarks      Bookmark[]  @relation("PlacementBookmarks")

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([company])
  @@index([authorId])
}

model Hackathon {
  id             String      @id @default(uuid())
  title          String
  description    String      @db.Text

  deadline       DateTime
  status         String      @default("OPEN") // OPEN, CLOSED, ONGOING
  
  // Relations
  author         User        @relation(fields: [authorId], references: [id])
  authorId       String
  
  bookmarks      Bookmark[]  @relation("HackathonBookmarks")
  applications   HackathonApplication[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([authorId])
}

model HackathonApplication {
  id             String      @id @default(uuid())
  hackathon      Hackathon   @relation(fields: [hackathonId], references: [id])
  hackathonId    String
  user           User        @relation(fields: [userId], references: [id])
  userId         String
  
  status         String      @default("PENDING") // PENDING, SELECTED, REJECTED

  
  // Registration Data
  fullName       String
  githubLink     String?
  linkedinLink   String?
  
  portfolioLink  String?
  resumeUrl      String?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, hackathonId])
}


model DiscussionThread {
  id             String      @id @default(uuid())
  title          String
  content        String      @db.Text

  
  // Relations
  author         User        @relation(fields: [authorId], references: [id])
  authorId       String
  
  // Denormalized Summary
  replyCount     Int         @default(0)
  
  replies        DiscussionReply[]
  tags           ThreadTag[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([authorId])
}

model DiscussionReply {
  id             String           @id @default(uuid())
  content        String           @db.Text

  
  // Relations
  thread         DiscussionThread @relation(fields: [threadId], references: [id])
  threadId       String
  author         User             @relation(fields: [authorId], references: [id])
  authorId       String
  
  // Denormalized Summary
  upvoteCount    Int              @default(0)
  
  isBlocker      Boolean          @default(false)
  
  upvotes        Upvote[]         @relation("ReplyUpvotes")

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([threadId])
  @@index([authorId])
}

model Announcement {
  id             String      @id @default(uuid())
  title          String
  content        String      @db.Text

  isSticky       Boolean     @default(false)
  visibility     Visibility  @default(UNIVERSITY_ONLY)
  
  // Relations
  author         User        @relation(fields: [authorId], references: [id])
  authorId       String      // Must be Campus Manager (validated in business logic)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([isSticky, createdAt])
  @@index([visibility, createdAt])
  @@index([authorId, createdAt])
}

model Tag {
  id             String      @id @default(uuid())
  name           String      @unique
  notes          NoteTag[]
  threads        ThreadTag[]
}

// Junction Tables for Many-to-Many
model NoteTag {
  note    Note   @relation(fields: [noteId], references: [id])
  noteId  String
  tag     Tag    @relation(fields: [tagId], references: [id])
  tagId   String

  @@id([noteId, tagId])
  @@index([tagId])
}

model ThreadTag {
  thread    DiscussionThread @relation(fields: [threadId], references: [id])
  threadId  String
  tag       Tag              @relation(fields: [tagId], references: [id])
  tagId     String

  @@id([threadId, tagId])
  @@index([tagId])
}

// Upvote Model (Polymorphic-ish via optional relations)
model Upvote {
  id             String           @id @default(uuid())
  user           User             @relation(fields: [userId], references: [id])
  userId         String

  // Optional relations to different post types
  note           Note?            @relation("NoteUpvotes", fields: [noteId], references: [id])
  noteId         String?
  placement      PlacementPost?   @relation("PlacementUpvotes", fields: [placementId], references: [id])
  placementId    String?
  reply          DiscussionReply? @relation("ReplyUpvotes", fields: [replyId], references: [id])
  replyId        String?

  createdAt      DateTime         @default(now())

  // Ensure one upvote per user per post type
  @@unique([userId, noteId])
  @@unique([userId, placementId])
  @@unique([userId, replyId])
}

// Bookmark Model
model Bookmark {
  id             String           @id @default(uuid())
  user           User             @relation(fields: [userId], references: [id])
  userId         String

  note           Note?            @relation("NoteBookmarks", fields: [noteId], references: [id])
  noteId         String?
  placement      PlacementPost?   @relation("PlacementBookmarks", fields: [placementId], references: [id])
  placementId    String?
  hackathon      Hackathon?       @relation("HackathonBookmarks", fields: [hackathonId], references: [id])
  hackathonId    String?

  createdAt      DateTime         @default(now())

  @@unique([userId, noteId])
  @@unique([userId, placementId])
  @@unique([userId, hackathonId])
}
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  UPVOTE
  ANNOUNCEMENT
  HACKATHON
  REPLY
}

model Notification {
  id          String           @id @default(uuid())
  user        User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  sender      User?            @relation("SentNotifications", fields: [senderId], references: [id])
  senderId    String?
  
  type        NotificationType @default(INFO)
  title       String
  message     String           @db.Text

  link        String?          // e.g. /notes/123
  
  isRead      Boolean          @default(false)
  
  createdAt   DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}
